# Copy to .env and fill in your keys.

# Groq — required for answer generation + RAGAS evaluation
# Free tier at https://console.groq.com — no credit card needed.
# Email jonas@vanbuel.dev for a shared project key.
GROQ_API_KEY=

# OpenAI — optional, enables text-embedding-3-small embedder
# Without this, only MiniLM and BGE-M3 (local) embedders are used.
OPENAI_API_KEY=